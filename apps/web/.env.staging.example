# RepMax staging environment
NEXT_PUBLIC_SUPABASE_URL=https://<staging-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<staging-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<staging-service-role-key>
PLAYWRIGHT_TEST_BASE_URL=https://staging.repmax.app

# ---------------------------------------------------------------------------
# Role-based credential overrides for Playwright journey tests.
#
# The journey runner checks PLAYWRIGHT_TEST_EMAIL_<ROLE> before falling back
# to the hardcoded synthetic email in each journey JSON. This lets you run
# the same journey files against staging with real personas.
#
# Map: JSON "role" field → env var suffix (uppercased)
#   athlete   → PLAYWRIGHT_TEST_EMAIL_ATHLETE / PLAYWRIGHT_TEST_PASSWORD_ATHLETE
#   recruiter → PLAYWRIGHT_TEST_EMAIL_RECRUITER / PLAYWRIGHT_TEST_PASSWORD_RECRUITER
#   coach     → PLAYWRIGHT_TEST_EMAIL_COACH / PLAYWRIGHT_TEST_PASSWORD_COACH
#   parent    → PLAYWRIGHT_TEST_EMAIL_PARENT / PLAYWRIGHT_TEST_PASSWORD_PARENT
#   club      → PLAYWRIGHT_TEST_EMAIL_CLUB / PLAYWRIGHT_TEST_PASSWORD_CLUB
#   school    → PLAYWRIGHT_TEST_EMAIL_SCHOOL / PLAYWRIGHT_TEST_PASSWORD_SCHOOL
#   admin     → PLAYWRIGHT_TEST_EMAIL_ADMIN / PLAYWRIGHT_TEST_PASSWORD_ADMIN
# ---------------------------------------------------------------------------

# Athlete — Wilson
PLAYWRIGHT_TEST_EMAIL_ATHLETE=wilson@repmax.io
PLAYWRIGHT_TEST_PASSWORD_ATHLETE=<password>

# Recruiter
PLAYWRIGHT_TEST_EMAIL_RECRUITER=<recruiter-email>
PLAYWRIGHT_TEST_PASSWORD_RECRUITER=<password>

# Coach — TCU
PLAYWRIGHT_TEST_EMAIL_COACH=coach.williams@test.repmax.io
PLAYWRIGHT_TEST_PASSWORD_COACH=<password>

# Parent
PLAYWRIGHT_TEST_EMAIL_PARENT=<parent-email>
PLAYWRIGHT_TEST_PASSWORD_PARENT=<password>

# Club
PLAYWRIGHT_TEST_EMAIL_CLUB=mike.torres@test.repmax.io
PLAYWRIGHT_TEST_PASSWORD_CLUB=<password>

# School — Sierra Canyon
PLAYWRIGHT_TEST_EMAIL_SCHOOL=sierracanyon@repmax.io
PLAYWRIGHT_TEST_PASSWORD_SCHOOL=<password>

# Admin
PLAYWRIGHT_TEST_EMAIL_ADMIN=<admin-email>
PLAYWRIGHT_TEST_PASSWORD_ADMIN=<password>

# Feature flags
ENABLE_SYNTHETIC_ATHLETES=false
