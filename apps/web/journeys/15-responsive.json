{
  "project": "repmax-v2",
  "group": "15-responsive",
  "name": "Mobile & Tablet Responsive Tests",
  "requiresAuth": true,
  "role": "athlete",
  "baseUrl": "http://localhost:3000",
  "env": {
    "TEST_EMAIL": "jaylen.washington@test.repmax.io",
    "TEST_PASSWORD": "TestPass123!"
  },
  "pages": [
    "/",
    "/pricing",
    "/athlete",
    "/athlete/film",
    "/messages",
    "/settings",
    "/help"
  ],
  "journeys": [
    {
      "name": "Mobile 390x844: landing page loads cleanly",
      "priority": "critical",
      "description": "Verify the landing page renders without errors at mobile viewport 390x844",
      "steps": [
        { "action": "set_viewport", "value": "390x844" },
        { "action": "navigate", "url": "/" },
        { "action": "wait", "value": "2000" },
        { "action": "assert_no_bad_text" },
        { "action": "assert_no_stuck_loading" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Mobile 390x844: landing hero CTAs visible",
      "priority": "critical",
      "description": "Verify signup and login links are visible in the hero section at mobile viewport",
      "steps": [
        { "action": "set_viewport", "value": "390x844" },
        { "action": "navigate", "url": "/" },
        { "action": "wait", "value": "2000" },
        { "action": "assert_visible", "selector": "a[href='/signup']" },
        { "action": "assert_text_present", "value": "Get Your Free RepMax ID" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Mobile 390x844: pricing page loads",
      "priority": "high",
      "description": "Verify the pricing page renders cleanly at mobile viewport with tabs visible",
      "steps": [
        { "action": "set_viewport", "value": "390x844" },
        { "action": "navigate", "url": "/pricing" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_no_bad_text" },
        { "action": "assert_text_present", "value": "Athletes" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Mobile 390x844: pricing tab switch works",
      "priority": "high",
      "description": "Verify pricing tab switching works on mobile by clicking Recruiters tab",
      "steps": [
        { "action": "set_viewport", "value": "390x844" },
        { "action": "navigate", "url": "/pricing" },
        { "action": "wait", "value": "3000" },
        { "action": "click", "selector": "button:has-text('Recruiters')" },
        { "action": "wait", "value": "1000" },
        { "action": "assert_text_present", "value": "ENTERPRISE" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Mobile 390x844: login form usable",
      "priority": "critical",
      "description": "Verify login form inputs and submit button are visible and usable at mobile viewport",
      "steps": [
        { "action": "set_viewport", "value": "390x844" },
        { "action": "navigate", "url": "/login" },
        { "action": "wait", "value": "2000" },
        { "action": "assert_visible", "selector": "input[type='email']" },
        { "action": "assert_visible", "selector": "input[type='password']" },
        { "action": "assert_visible", "selector": "button[type='submit']" },
        { "action": "assert_text_present", "value": "Sign In" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Mobile 390x844: login and athlete dashboard redirect",
      "priority": "critical",
      "description": "Login as athlete at mobile viewport and verify dashboard loads successfully",
      "steps": [
        { "action": "set_viewport", "value": "390x844" },
        { "action": "navigate", "url": "/login" },
        { "action": "fill", "selector": "input[type='email']", "value": "{{TEST_EMAIL}}" },
        { "action": "fill", "selector": "input[type='password']", "value": "{{TEST_PASSWORD}}" },
        { "action": "click", "selector": "button[type='submit']" },
        { "action": "wait", "value": "4000" },
        { "action": "assert_no_bad_text" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Mobile 390x844: athlete dashboard no bad text, no stuck loading",
