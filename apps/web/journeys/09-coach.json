{
  "project": "repmax-v2",
  "group": "09-coach",
  "name": "Coach Dashboard, Roster & Tasks",
  "requiresAuth": true,
  "role": "coach",
  "baseUrl": "http://localhost:3000",
  "env": {
    "TEST_EMAIL": "coach.davis@test.repmax.io",
    "TEST_PASSWORD": "TestPass123!"
  },
  "pages": [
    "/coach",
    "/coach/roster",
    "/coach/roster/new",
    "/coach/tasks"
  ],
  "journeys": [
    {
      "name": "Login as coach and redirect to dashboard",
      "priority": "critical",
      "description": "Coach logs in with valid credentials and lands on the coach dashboard",
      "steps": [
        { "action": "navigate", "url": "/login" },
        { "action": "wait", "value": "2000" },
        { "action": "fill", "selector": "input[type='email']", "value": "{{TEST_EMAIL}}" },
        { "action": "fill", "selector": "input[type='password']", "value": "{{TEST_PASSWORD}}" },
        { "action": "click", "selector": "button[type='submit']" },
        { "action": "wait", "value": "4000" },
        { "action": "assert_no_bad_text" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Dashboard heading and subtitle visible",
      "priority": "critical",
      "description": "Coach dashboard displays Team Roster heading and athlete count",
      "steps": [
        { "action": "navigate", "url": "/login" },
        { "action": "fill", "selector": "input[type='email']", "value": "{{TEST_EMAIL}}" },
        { "action": "fill", "selector": "input[type='password']", "value": "{{TEST_PASSWORD}}" },
        { "action": "click", "selector": "button[type='submit']" },
        { "action": "wait", "value": "4000" },
        { "action": "navigate", "url": "/coach" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_text_present", "value": "Team Roster" },
        { "action": "assert_text_present", "value": "Athletes" },
        { "action": "assert_no_bad_text" },
        { "action": "assert_no_stuck_loading" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Dashboard 4 metric cards render",
      "priority": "high",
      "description": "Dashboard shows Total Athletes, With Offers, Committed, and Pending Tasks metric cards",
      "steps": [
        { "action": "navigate", "url": "/coach" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_text_present", "value": "Total Athletes" },
        { "action": "assert_text_present", "value": "With Offers" },
        { "action": "assert_text_present", "value": "Committed" },
        { "action": "assert_text_present", "value": "Pending Tasks" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Dashboard no bad text and no stuck loading",
      "priority": "high",
      "description": "Dashboard renders without error text, undefined values, or stuck loading spinners",
      "steps": [
        { "action": "navigate", "url": "/coach" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_no_bad_text" },
        { "action": "assert_no_stuck_loading" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Dashboard roster table with column headers",
      "priority": "critical",
      "description": "Roster table shows Athlete, Position, Class, GPA, Offers, Status, Actions column headers",
      "steps": [
        { "action": "navigate", "url": "/coach" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_text_present", "value": "Athlete" },
        { "action": "assert_text_present", "value": "Position" },
        { "action": "assert_text_present", "value": "Class" },
        { "action": "assert_text_present", "value": "Status" },
        { "action": "assert_text_present", "value": "Actions" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Dashboard position filter select",
      "priority": "high",
      "description": "Position filter select has All Positions, QB, RB, WR, LB, CB options",
      "steps": [
        { "action": "navigate", "url": "/coach" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_visible", "selector": "select" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Dashboard position filter selects QB",
      "priority": "high",
      "description": "Selecting QB from position filter updates the roster table to show only QB athletes",
      "steps": [
        { "action": "navigate", "url": "/coach" },
        { "action": "wait", "value": "3000" },
        { "action": "fill", "selector": "select >> nth=0", "value": "QB" },
        { "action": "wait", "value": "1000" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Dashboard class year filter selects 2026",
      "priority": "high",
      "description": "Selecting 2026 from class year filter updates the roster table",
      "steps": [
        { "action": "navigate", "url": "/coach" },
        { "action": "wait", "value": "3000" },
        { "action": "fill", "selector": "select >> nth=1", "value": "2026" },
        { "action": "wait", "value": "1000" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Dashboard select-all checkbox in table header",
      "priority": "high",
      "description": "Table header has a select-all checkbox that toggles all row checkboxes",
      "steps": [
        { "action": "navigate", "url": "/coach" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_visible", "selector": "thead input[type='checkbox']" },
        { "action": "click", "selector": "thead input[type='checkbox']" },
        { "action": "wait", "value": "500" },
        { "action": "assert_text_present", "value": "selected" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Dashboard individual row checkbox toggles",
      "priority": "medium",
      "description": "Clicking a row checkbox selects that individual athlete and shows selection count",
      "steps": [
        { "action": "navigate", "url": "/coach" },
        { "action": "wait", "value": "3000" },
        { "action": "click", "selector": "tbody input[type='checkbox'] >> nth=0" },
        { "action": "wait", "value": "500" },
        { "action": "assert_text_present", "value": "selected" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Dashboard Export Selected button appears when rows selected",
      "priority": "high",
      "description": "Selecting athletes reveals Export Selected and Send to Recruiter bulk action buttons",
      "steps": [
        { "action": "navigate", "url": "/coach" },
        { "action": "wait", "value": "3000" },
        { "action": "click", "selector": "thead input[type='checkbox']" },
        { "action": "wait", "value": "500" },
        { "action": "assert_visible", "selector": "button:has-text('Export Selected')" },
        { "action": "assert_visible", "selector": "button:has-text('Send to Recruiter')" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Dashboard Export Selected triggers CSV download",
      "priority": "high",
      "description": "Clicking Export Selected button triggers a CSV file download",
      "steps": [
        { "action": "navigate", "url": "/coach" },
        { "action": "wait", "value": "3000" },
        { "action": "click", "selector": "thead input[type='checkbox']" },
        { "action": "wait", "value": "500" },
        { "action": "click", "selector": "button:has-text('Export Selected')" },
        { "action": "wait", "value": "1000" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Dashboard Send to Recruiter opens ComposeMessageModal",
