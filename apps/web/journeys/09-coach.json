        { "action": "wait", "value": "3000" },
        { "action": "click", "selector": "thead input[type='checkbox']" },
        { "action": "wait", "value": "500" },
        { "action": "click", "selector": "button:has-text('Send to Recruiter')" },
        { "action": "wait", "value": "1000" },
        { "action": "assert_text_present", "value": "New Message" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "ComposeMessageModal fields and controls",
