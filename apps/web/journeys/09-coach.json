        { "action": "navigate", "url": "/coach" },
        { "action": "wait", "value": "3000" },
        { "action": "click", "selector": "thead input[type='checkbox']" },
        { "action": "wait", "value": "500" },
        { "action": "click", "selector": "button:has-text('Send to Recruiter')" },
        { "action": "wait", "value": "1000" },
        { "action": "assert_text_present", "value": "New Message" },
        { "action": "assert_text_present", "value": "To:" },
        { "action": "assert_text_present", "value": "Subject" },
        { "action": "assert_text_present", "value": "Message" },
        { "action": "assert_text_present", "value": "NCAA Compliance" },
        { "action": "assert_visible", "selector": "button:has-text('Send Message')" },
        { "action": "assert_visible", "selector": "button:has-text('Cancel')" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "ComposeMessageModal Cancel closes modal",
      "priority": "medium",
      "description": "Clicking Cancel in the compose modal closes it and returns to the dashboard",
      "steps": [
        { "action": "navigate", "url": "/coach" },
        { "action": "wait", "value": "3000" },
        { "action": "click", "selector": "thead input[type='checkbox']" },
        { "action": "wait", "value": "500" },
        { "action": "click", "selector": "button:has-text('Send to Recruiter')" },
        { "action": "wait", "value": "1000" },
        { "action": "assert_text_present", "value": "New Message" },
        { "action": "click", "selector": "button:has-text('Cancel')" },
        { "action": "wait", "value": "500" },
        { "action": "assert_no_text", "value": "New Message" },
        { "action": "screenshot" }
      ]
