{
  "project": "repmax-v2",
  "group": "08-recruiter-tools",
  "name": "Recruiter Visits, Comms & Reports",
  "requiresAuth": true,
  "role": "recruiter",
  "baseUrl": "http://localhost:3000",
  "env": {
    "TEST_EMAIL": "coach.williams@test.repmax.io",
    "TEST_PASSWORD": "TestPass123!"
  },
  "pages": [
    "/recruiter/visits",
    "/recruiter/communications",
    "/recruiter/reports",
    "/recruiter/film"
  ],
  "journeys": [
    {
      "name": "Login as recruiter",
      "priority": "critical",
      "description": "Recruiter logs in with valid credentials and session is established",
      "steps": [
        { "action": "navigate", "url": "/login" },
        { "action": "wait", "value": "2000" },
        { "action": "fill", "selector": "input[type='email']", "value": "{{TEST_EMAIL}}" },
        { "action": "fill", "selector": "input[type='password']", "value": "{{TEST_PASSWORD}}" },
        { "action": "click", "selector": "button[type='submit']" },
        { "action": "wait", "value": "4000" },
        { "action": "assert_no_bad_text" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Visits page loads with heading and stats",
      "priority": "critical",
      "description": "Campus Visits page renders heading, subtitle, and 4 stat cards without errors",
      "steps": [
        { "action": "navigate", "url": "/login" },
        { "action": "fill", "selector": "input[type='email']", "value": "{{TEST_EMAIL}}" },
        { "action": "fill", "selector": "input[type='password']", "value": "{{TEST_PASSWORD}}" },
        { "action": "click", "selector": "button[type='submit']" },
        { "action": "wait", "value": "4000" },
        { "action": "navigate", "url": "/recruiter/visits" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_text_present", "value": "Campus Visits" },
        { "action": "assert_text_present", "value": "Official Visits" },
        { "action": "assert_text_present", "value": "Pending" },
        { "action": "assert_text_present", "value": "Win Rate" },
        { "action": "assert_no_bad_text" },
        { "action": "assert_no_stuck_loading" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Visits calendar month view renders",
      "priority": "high",
      "description": "Calendar displays day-of-week header row and numbered day cells in month view",
      "steps": [
        { "action": "navigate", "url": "/recruiter/visits" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_text_present", "value": "Sun" },
        { "action": "assert_text_present", "value": "Mon" },
        { "action": "assert_text_present", "value": "Fri" },
        { "action": "assert_text_present", "value": "Sat" },
        { "action": "assert_visible", "selector": "button:has-text('Month')" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Visits calendar view mode toggle (Month/Week/Day)",
      "priority": "high",
      "description": "Calendar view mode buttons are visible and clickable to switch between Month, Week, and Day views",
      "steps": [
        { "action": "navigate", "url": "/recruiter/visits" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_visible", "selector": "button:has-text('Month')" },
        { "action": "assert_visible", "selector": "button:has-text('Week')" },
        { "action": "assert_visible", "selector": "button:has-text('Day')" },
        { "action": "click", "selector": "button:has-text('Week')" },
        { "action": "wait", "value": "1000" },
        { "action": "screenshot" },
        { "action": "click", "selector": "button:has-text('Day')" },
        { "action": "wait", "value": "1000" },
        { "action": "screenshot" },
        { "action": "click", "selector": "button:has-text('Month')" },
        { "action": "wait", "value": "1000" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Visits calendar month navigation (prev/next)",
      "priority": "medium",
      "description": "Chevron buttons navigate to previous and next months",
      "steps": [
        { "action": "navigate", "url": "/recruiter/visits" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_visible", "selector": "span.material-symbols-outlined:has-text('chevron_left')" },
        { "action": "click", "selector": "button:has(span:has-text('chevron_left'))" },
        { "action": "wait", "value": "1000" },
        { "action": "screenshot" },
        { "action": "click", "selector": "button:has(span:has-text('chevron_right'))" },
        { "action": "wait", "value": "1000" },
        { "action": "click", "selector": "button:has(span:has-text('chevron_right'))" },
        { "action": "wait", "value": "1000" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Schedule Visit button visible",
      "priority": "high",
      "description": "Visits page has a visible Schedule Visit button in the header",
      "steps": [
        { "action": "navigate", "url": "/recruiter/visits" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_visible", "selector": "button:has-text('Schedule Visit')" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Schedule Visit button opens modal",
      "priority": "critical",
      "description": "Clicking Schedule Visit opens the modal with form fields for scheduling a campus visit",
      "steps": [
        { "action": "navigate", "url": "/recruiter/visits" },
        { "action": "wait", "value": "3000" },
        { "action": "click", "selector": "button:has-text('Schedule Visit')" },
        { "action": "wait", "value": "1000" },
        { "action": "assert_text_present", "value": "Schedule Campus Visit" },
        { "action": "assert_visible", "selector": "input[placeholder='Enter athlete ID']" },
        { "action": "assert_visible", "selector": "input[type='date']" },
        { "action": "assert_visible", "selector": "select" },
        { "action": "assert_visible", "selector": "input[type='time']" },
        { "action": "assert_visible", "selector": "textarea" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Schedule Visit modal form fields populated",
      "priority": "high",
      "description": "Modal form fields for Athlete ID, Visit Date, Visit Type, Time, and Notes are fillable",
      "steps": [
        { "action": "navigate", "url": "/recruiter/visits" },
        { "action": "wait", "value": "3000" },
        { "action": "click", "selector": "button:has-text('Schedule Visit')" },
        { "action": "wait", "value": "1000" },
        { "action": "fill", "selector": "input[placeholder='Enter athlete ID']", "value": "test-athlete-123" },
        { "action": "fill", "selector": "input[type='date']", "value": "2026-03-15" },
        { "action": "fill", "selector": "input[type='time']", "value": "10:00" },
        { "action": "fill", "selector": "textarea", "value": "Test visit notes for campus tour" },
        { "action": "assert_visible", "selector": "button[type='submit']:has-text('Schedule Visit')" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Schedule Visit modal cancel closes modal",
      "priority": "medium",
      "description": "Clicking Cancel in the Schedule Visit modal closes it and returns to the visits page",
      "steps": [
        { "action": "navigate", "url": "/recruiter/visits" },
        { "action": "wait", "value": "3000" },
        { "action": "click", "selector": "button:has-text('Schedule Visit')" },
        { "action": "wait", "value": "1000" },
        { "action": "assert_text_present", "value": "Schedule Campus Visit" },
        { "action": "click", "selector": "button[type='button']:has-text('Cancel')" },
        { "action": "wait", "value": "500" },
        { "action": "assert_no_text", "value": "Schedule Campus Visit" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Visits color key legend visible",
      "priority": "low",
      "description": "Calendar legend shows Official Visit, Unofficial Visit, and Junior Day color keys",
      "steps": [
        { "action": "navigate", "url": "/recruiter/visits" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_text_present", "value": "Official Visit" },
        { "action": "assert_text_present", "value": "Unofficial Visit" },
        { "action": "assert_text_present", "value": "Junior Day" },
        { "action": "screenshot" }
