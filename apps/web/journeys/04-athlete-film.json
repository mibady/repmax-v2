{
  "project": "repmax-v2",
  "group": "04-athlete-film",
  "name": "Athlete Film Room",
  "requiresAuth": true,
  "role": "athlete",
  "baseUrl": "http://localhost:3000",
  "env": {
    "TEST_EMAIL": "jaylen.washington@test.repmax.io",
    "TEST_PASSWORD": "TestPass123!"
  },
  "pages": ["/athlete/film"],
  "journeys": [
    {
      "name": "Film page loads with heading",
      "priority": "critical",
      "description": "Authenticate and verify the Film Room page loads with the 'Your Highlights' heading",
      "steps": [
        { "action": "navigate", "url": "/login" },
        { "action": "fill", "selector": "input[type='email']", "value": "{{TEST_EMAIL}}" },
        { "action": "fill", "selector": "input[type='password']", "value": "{{TEST_PASSWORD}}" },
        { "action": "click", "selector": "button[type='submit']" },
        { "action": "wait", "value": "4000" },
        { "action": "navigate", "url": "/athlete/film" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_text_present", "value": "Your Highlights" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Film page no bad text",
      "priority": "critical",
      "description": "Verify the Film Room page has no undefined, NaN, or [object Object] rendering bugs",
      "steps": [
        { "action": "navigate", "url": "/login" },
        { "action": "fill", "selector": "input[type='email']", "value": "{{TEST_EMAIL}}" },
        { "action": "fill", "selector": "input[type='password']", "value": "{{TEST_PASSWORD}}" },
        { "action": "click", "selector": "button[type='submit']" },
        { "action": "wait", "value": "4000" },
        { "action": "navigate", "url": "/athlete/film" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_no_bad_text" },
        { "action": "assert_no_text", "value": "undefined" },
        { "action": "assert_no_text", "value": "NaN" },
        { "action": "assert_no_text", "value": "[object Object]" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Film page no stuck loading",
      "priority": "critical",
      "description": "Verify the Film Room page finishes loading without stuck spinners or skeleton states",
      "steps": [
        { "action": "navigate", "url": "/login" },
        { "action": "fill", "selector": "input[type='email']", "value": "{{TEST_EMAIL}}" },
        { "action": "fill", "selector": "input[type='password']", "value": "{{TEST_PASSWORD}}" },
        { "action": "click", "selector": "button[type='submit']" },
        { "action": "wait", "value": "4000" },
        { "action": "navigate", "url": "/athlete/film" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_no_stuck_loading" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Film page console clean",
