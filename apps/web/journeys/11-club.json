{
  "project": "repmax-v2",
  "group": "11-club",
  "name": "Club Dashboard & Event Management",
  "requiresAuth": true,
  "role": "club",
  "baseUrl": "http://localhost:3000",
  "env": {
    "TEST_EMAIL": "mike.torres@test.repmax.io",
    "TEST_PASSWORD": "TestPass123!"
  },
  "pages": [
    "/club",
    "/club/events",
    "/club/events/new",
    "/club/athletes",
    "/club/verifications",
    "/club/payments",
    "/club/scouts",
    "/club/analytics"
