  "journeys": [
    {
      "name": "Login as club user and redirect to dashboard",
      "priority": "critical",
      "description": "Authenticate as club user and verify redirect to /club dashboard",
      "steps": [
        { "action": "navigate", "url": "/login" },
        { "action": "fill", "selector": "input[type='email']", "value": "{{TEST_EMAIL}}" },
        { "action": "fill", "selector": "input[type='password']", "value": "{{TEST_PASSWORD}}" },
        { "action": "click", "selector": "button[type='submit']" },
        { "action": "wait", "value": "4000" },
        { "action": "assert_url_contains", "value": "/club" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Dashboard loads without errors or bad text",
      "priority": "critical",
      "description": "Verify the club dashboard renders cleanly without error text, undefined values, or stuck loading states",
      "steps": [
        { "action": "navigate", "url": "/login" },
        { "action": "fill", "selector": "input[type='email']", "value": "{{TEST_EMAIL}}" },
        { "action": "fill", "selector": "input[type='password']", "value": "{{TEST_PASSWORD}}" },
        { "action": "click", "selector": "button[type='submit']" },
        { "action": "wait", "value": "4000" },
        { "action": "navigate", "url": "/club" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_no_bad_text" },
        { "action": "assert_no_stuck_loading" },
        { "action": "assert_console_clean" },
        { "action": "screenshot" }
      ]
    },
