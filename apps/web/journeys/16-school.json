{
  "project": "repmax-v2",
  "group": "16-school",
  "name": "School Dashboard, Members & Billing",
  "requiresAuth": true,
  "role": "school",
  "baseUrl": "http://localhost:3000",
  "env": {
    "TEST_EMAIL": "school.admin@test.repmax.io",
    "TEST_PASSWORD": "TestPass123!"
  },
  "pages": [
    "/school",
    "/school/members",
    "/school/settings",
    "/school/billing",
    "/school/dashr",
    "/school/events",
    "/school/events/my"
  ],
  "journeys": [
    {
      "name": "Login as school user and redirect to dashboard",
      "priority": "critical",
      "description": "Authenticate as school admin user and verify redirect to the school dashboard",
      "steps": [
        { "action": "navigate", "url": "/login" },
        { "action": "wait", "value": "2000" },
        { "action": "fill", "selector": "input[type='email']", "value": "{{TEST_EMAIL}}" },
        { "action": "fill", "selector": "input[type='password']", "value": "{{TEST_PASSWORD}}" },
        { "action": "click", "selector": "button[type='submit']" },
        { "action": "wait", "value": "4000" },
        { "action": "navigate", "url": "/school" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_no_bad_text" },
        { "action": "assert_url_contains", "value": "/school" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Dashboard loads without bad text or stuck loading",
      "priority": "critical",
      "description": "Verify the school dashboard renders completely with no error text or stuck spinners",
      "steps": [
        { "action": "navigate", "url": "/school" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_no_bad_text" },
        { "action": "assert_no_stuck_loading" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Dashboard: Total Members stat card visible",
      "priority": "high",
      "description": "Verify the Total Members stat card is rendered on the dashboard",
      "steps": [
        { "action": "navigate", "url": "/school" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_text_present", "value": "Total Members" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Dashboard: Active Events stat card visible",
      "priority": "high",
