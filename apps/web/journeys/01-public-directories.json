    {
      "name": "Auth guard: /tournaments redirects to login",
      "priority": "critical",
      "description": "Verify that the protected /tournaments route redirects unauthenticated users to /login",
      "steps": [
        { "action": "navigate", "url": "/tournaments" },
        { "action": "wait", "value": "3000" },
