        { "action": "wait", "value": "3000" },
        { "action": "assert_url_contains", "value": "/login" },
        { "action": "navigate", "url": "/coach" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_url_contains", "value": "/login" },
        { "action": "navigate", "url": "/parent" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_url_contains", "value": "/login" },
        { "action": "navigate", "url": "/club" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_url_contains", "value": "/login" },
        { "action": "navigate", "url": "/school" },
