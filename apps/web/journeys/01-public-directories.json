    {
      "name": "Programs north-shore loads with program name",
      "priority": "high",
      "description": "Verify the North Shore program page renders with the school name",
      "steps": [
        { "action": "navigate", "url": "/programs/north-shore" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_text_present", "value": "North Shore High School" },
        { "action": "assert_text_present", "value": "Houston, TX" },
        { "action": "assert_no_bad_text" },
        { "action": "assert_no_stuck_loading" },
        { "action": "screenshot" }
      ]
