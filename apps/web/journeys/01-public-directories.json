    {
      "name": "Auth guard: protected role dashboards redirect to login",
      "priority": "critical",
      "description": "Verify that all protected role routes redirect unauthenticated users to /login",
      "steps": [
        { "action": "navigate", "url": "/recruiter/pipeline" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_url_contains", "value": "/login" },
