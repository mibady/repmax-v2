      "steps": [
        { "action": "navigate", "url": "/states/tx" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_visible", "selector": "a[href='/signup']:has-text('Get Scouted')" },
        { "action": "screenshot" }
