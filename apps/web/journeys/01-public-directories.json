    {
      "name": "Programs stats grid shows D1 Prospects and Athletes on RepMax",
      "priority": "medium",
      "description": "Verify the program page displays D1 Prospects and Athletes on RepMax stat cards",
      "steps": [
        { "action": "navigate", "url": "/programs/north-shore" },
        { "action": "wait", "value": "3000" },
        { "action": "assert_text_present", "value": "D1 Prospects" },
        { "action": "assert_text_present", "value": "Athletes on RepMax" },
        { "action": "assert_text_present", "value": "159" },
        { "action": "screenshot" }
      ]
    },
    {
      "name": "Programs Follow button and Create Profile CTA",
      "priority": "medium",
      "description": "Verify the program page has Follow This Program button and Create RepMax Profile link to /signup",
      "steps": [
        { "action": "navigate", "url": "/programs/north-shore" },
